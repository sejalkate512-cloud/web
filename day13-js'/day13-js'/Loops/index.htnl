<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <script>
     //Loop : Once The Loop is Started You Should Know How To The Stop The Loop
     //Condition is True Loop Starts And Condition is False Loop Stop

        //Task Print Number 1 to 10
        //    console.log(1)
        //    console.log(2)
        //    console.log(3) ... 10 Times

      //for(starting point;  ending/condition; ++ or --){
        //Task
    // }

      //Task Print Number 1 to 10

      for(let i = 1; i <= 10; i++ ){
            
        console.log("The Value is " ,  i)

      }

      //Print Number 10 to 1

      for(let y=10   ; y >= 1; y--  ){
            
        console.log("The Value is " ,  y)

      }


      //while loop - Entry Controller Loop

    //  while(condition) : Condition is True While Loop Starts and Condition is false While Loop Stops

     let count = 1

     while(count <= 5){

        console.log("Hello I am While Loop")
        count++

     }


     //Do While Loop - Exit Controlled Loop
     // It Will Run/Execute Your Code Atleast For One Time, Even if Your COndition is False

     let number = 7

     do{
        console.log("Hii I am Do While Loop")
     }while(number < 5)




     </script>   
</body>
</html>